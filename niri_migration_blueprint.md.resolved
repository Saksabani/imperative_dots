## New Config: `~/.config/niri/config.kdl`

```kdl
// Translated from your Hyprland config

input {
    keyboard {
        xkb {
            layout "us"
            options "grp:alt_shift_toggle"
        }
    }
    touchpad {
        tap
        natural-scroll
    }
}

// Named workspaces to match your current 1-8 model
workspace "1" {}
workspace "2" {}
workspace "3" {}
workspace "4" {}
workspace "5" {}
workspace "6" {}
workspace "7" {}
workspace "8" {}

output "eDP-1" {
    mode "preferred"
    scale 1.0
}

layout {
    gaps 4
    border {
        width 2
        active-color "#f1b3e6"
        inactive-color "#663560"
    }
    default-column-width { proportion 0.5; }
}

environment {
    NIXOS_OZONE_WL "1"
}

cursor {
    hide-when-typing
}

// Autostart
spawn-at-startup "quickshell" "-p" "~/.config/niri/scripts/quickshell/Main.qml"
spawn-at-startup "quickshell" "-p" "~/.config/niri/scripts/quickshell/TopBar.qml"
spawn-at-startup "swayidle" "-w" "timeout" "600" "loginctl lock-session" "timeout" "1200" "systemctl suspend" "before-sleep" "loginctl lock-session"
spawn-at-startup "playerctld"
spawn-at-startup "swayosd-server" "--top-margin" "0.9" "--style" "$HOME/.config/swayosd/style.css"
spawn-sh-at-startup "wl-paste --type text --watch cliphist store"
spawn-sh-at-startup "wl-paste --type image --watch cliphist store"
spawn-sh-at-startup "~/.config/niri/scripts/init.sh"
spawn-sh-at-startup "~/.config/niri/scripts/settings_watcher.sh &"
spawn-sh-at-startup "~/.config/niri/scripts/volume_listener.sh"
spawn-sh-at-startup "~/.config/niri/scripts/update_notifier.sh"
spawn-sh-at-startup "python3 ~/.config/niri/scripts/quickshell/focustime/focus_daemon.py &"

// Window rules
window-rule {
    match title="app-launcher"
    open-floating true
}
window-rule {
    match title="qs-master"
    open-floating true
}

binds {
    // Applications
    Mod+Return { spawn "kitty"; }
    Mod+F { spawn "firefox"; }
    Mod+E { spawn "nautilus"; }

    // Window Management
    Alt+F4 { close-window; }
    Mod+Left { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up { focus-window-up; }
    Mod+Down { focus-window-down; }
    Mod+Shift+F { toggle-window-floating; }
    Mod+Shift+Left { set-column-width "-50"; }
    Mod+Shift+Right { set-column-width "+50"; }
    Mod+Ctrl+Left { move-column-left; }
    Mod+Ctrl+Right { move-column-right; }

    // QuickShell widgets
    Mod+D { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "applauncher"; }
    Mod+R { spawn "bash" "~/.config/niri/scripts/reload.sh"; }
    Mod+C { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "clipboard"; }
    Mod+P { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "movies"; }
    Mod+Shift+S { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "settings"; }
    Mod+Q { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "music"; }
    Mod+B { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "battery"; }
    Mod+W { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "wallpaper"; }
    Mod+S { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "calendar"; }
    Mod+N { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "network"; }
    Mod+Shift+T { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "focustime"; }
    Mod+V { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "volume"; }
    Mod+H { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "guide"; }
    Mod+M { spawn "bash" "~/.config/niri/scripts/qs_manager.sh" "toggle" "monitors"; }

    // Workspaces
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
